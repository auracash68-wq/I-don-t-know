{
  "expo": {
    "name": "Prompt Lab",
    "slug": "prompt-lab",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/ic_launchergs.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/ic_launchergs.png",
        "backgroundColor": "#0A0A0A"
      },
      "package": "com.promptlab.ai.premium",
      "targetSdkVersion": 36
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "react-native-reanimated/plugin"
    ]
  }
}
