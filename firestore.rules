rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128; }
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // explore_prompts
    match /explore_prompts/{promptId} {
      allow read: if true; // Public marketplace
      allow write: if false; // Only via admin panel (not implemented in this client app)
    }

    // payment_submissions
    match /payment_submissions/{subId} {
      allow create: if true; // Public submission
      allow read, update, delete: if false; // Only admin can read/verify
    }

    // approved_devices
    match /approved_devices/{deviceId} {
      allow read: if true; // Users can check if they are premium
      allow write: if false; // Only admin can unlock
    }
  }
}
